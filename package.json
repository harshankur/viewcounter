{
  "name": "viewcounter",
  "description": "A middleware backend server that registers views to my db server when requested to register a view from my other projects.",
  "version": "3.0.0",
  "main": "index.js",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "index.js",
    "constants.js",
    "config/",
    "db/",
    "middleware/",
    "routes/",
    "utils/",
    "scripts/setup.js",
    ".env.example",
    "allowed.sample.json",
    "dbInfo.sample.json"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "start": "node index.js",
    "setup": "node scripts/setup.js",
    "assets": "node scripts/generate-brand-assets.js",
    "lint": "eslint .",
    "test": "npm run lint && jest --coverage --verbose && node scripts/generate-test-report.js",
    "test:watch": "jest --watch",
    "test:ci": "npm run lint && jest --coverage --ci",
    "test:persist": "PERSIST_TEST_DB=true jest --coverage --verbose && node scripts/generate-test-report.js",
    "test:e2e": "bash tests/e2e/matrix.sh",
    "e2e:up": "docker compose -f docker-compose.e2e.yml up -d --wait",
    "e2e:down": "docker compose -f docker-compose.e2e.yml down -v"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "eslint": "^9.39.5",
    "jest": "^30.4.2",
    "jest-html-reporter": "^4.4.0",
    "supertest": "^7.2.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harshankur/viewcounter.git"
  },
  "keywords": [
    "viewcounter",
    "analytics",
    "tracking",
    "mysql",
    "middleware",
    "privacy-first"
  ],
  "author": "Harsh Ankur",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/harshankur/viewcounter/issues"
  },
  "homepage": "https://harshankur.github.io/viewcounter/",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "express-validator": "^7.3.2",
    "geoip-country": "^5.0.202607180103",
    "helmet": "^8.3.0",
    "mysql2": "^3.23.0",
    "ua-parser-js": "^2.0.10",
    "url-parse": "^1.5.10"
  },
  "overrides": {
    "geoip-country": {
      "ip-address": "^10.2.0"
    }
  }
}
